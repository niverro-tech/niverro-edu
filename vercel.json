{
    "version": 2,
    "public": true,
    "buildCommand": null,
    "outputDirectory": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/(.*)\\.(jpg|jpeg|png|webp|avif|css|js)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}